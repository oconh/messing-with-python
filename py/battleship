class player:
    def __init__(self, name, playArea):
      """
      A player has a name and a play area.

        - a name
        - a PlayArea (their grid)
        - a list of ships they own
      """
      self.name = name
      self.playArea = playArea
      self.ships = []

    def add_ship(self, ship):
        """
        Adds a ship object to the player's list of ships.
        """
        self.ships.append(ship)

    def place_ship(self, ship, start_coord, orientation):
        """
        Uses the PlayArea to place the ship on the grid.
        Returns True if placed successfully, False otherwise.
        """
        return self.play_area.place_ship(ship, start_coord, orientation)

    def attack(self, opponent, coord):
        """
        Attacks the opponent's play area.
        Returns the result from opponent's PlayArea.attack().
        """
        return opponent.play_area.attack(coord)

    def has_lost(self):
        """
        Player loses when all their ships are sunk.
        """
        return all(ship.is_sunk() for ship in self.ships)

    def view_grid(self, reveal_ships=False):
        """
        Shows the player's grid.
        reveal_ships=True will show where ships are (useful for debugging).
        """
        self.play_area.view_grid(reveal_ships=reveal_ships)



class playArea:
    def __init__(self, size=10):
        """
        Creates an NxN grid for Battleship.
        Each cell stores:
          - None  = empty
          - "miss" = attacked and empty
          - Ship object = ship occupies this cell
          - ("hit", Ship) = attacked and hit that ship
        """
        self.size = size
        self.grid = [[None for _ in range(size)] for _ in range(size)]

    # Ship Placement
    def place_ship(self, ship, start_coord, orientation):
        """
        Place a ship starting at (x, y) with orientation 'H' or 'V'.
        Returns True if successful, False if blocked or out-of-bounds.
        """

        x, y = start_coord.x, start_coord.y
        dx, dy = (1, 0) if orientation.upper() == "H" else (0, 1)

        coords_to_fill = []

        # Check bounds + collision
        for i in range(ship.length):
            nx, ny = x + dx * i, y + dy * i

            if not self._in_bounds(nx, ny):
                return False

            if self.grid[ny][nx] is not None:
                return False

            coords_to_fill.append((nx, ny))

        # Place ship & record coordinates
        ship.coordinates = coords_to_fill

        for (cx, cy) in coords_to_fill:
            self.grid[cy][cx] = ship

        return True

    # Attack Handling
    def attack(self, coord):
        """
        Attack a coordinate. Returns:
            "miss"
            "hit"
            "sunk"
        """
        x, y = coord.x, coord.y

        if not self._in_bounds(x, y):
            return "invalid"

        cell = self.grid[y][x]

        # Already attacked?
        if cell == "miss" or (isinstance(cell, tuple) and cell[0] == "hit"):
            return "repeat"

        # Miss
        if cell is None:
            self.grid[y][x] = "miss"
            return "miss"

        # Hit
        if isinstance(cell, Ship):
            ship = cell
            ship.register_hit()
            self.grid[y][x] = ("hit", ship)

            if ship.is_sunk():
                return "sunk"
            else:
                return "hit"

        return "error"

    # Display Grid
    def view_grid(self, reveal_ships=False):
        """
        Shows grid to console.
        """
        for row in self.grid:
            line = ""
            for cell in row:
                if cell is None:
                    line += ". "
                elif cell == "miss":
                    line += "o "
                elif isinstance(cell, tuple) and cell[0] == "hit":
                    line += "X "
                elif isinstance(cell, Ship):
                    line += ("S " if reveal_ships else ". ")
            print(line)

    # Helpers
    def _in_bounds(self, x, y):
        return 0 <= x < self.size and 0 <= y < self.size



